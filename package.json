{
  "name": "expert-contacts-microservice",
  "version": "1.0.0",
  "description": "Expert sourcing and contact management microservice",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development node src/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js'",
    "docker:build": "docker build -t expert-contacts-microservice .",
    "docker:run": "docker run -p 3600:3600 --env-file .env expert-contacts-microservice"
  },
  "dependencies": {
    "openai": "^4.70.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "pino": "^8.16.2",
    "pino-http": "^8.5.1",
    "@google-cloud/firestore": "^7.11.3",
    "node-fetch": "^3.3.2",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "jest": "^30.0.4",
    "supertest": "^7.1.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "pino-pretty": "^10.3.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "expert-sourcing",
    "ai",
    "openai",
    "microservice"
  ],
  "author": "Expert Contacts",
  "license": "MIT"
}